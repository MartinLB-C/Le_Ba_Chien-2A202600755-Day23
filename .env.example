# LLM API key (required — pick one)
# Alibaba DashScope (Qwen) API
DASHSCOPE_API_KEY=sk-your-dashscope-key

# Other providers
# GEMINI_API_KEY=AIza...
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Model configuration for Alibaba
LLM_MODEL=qwen-plus
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Optional: real HITL interrupts (default: mock approval)
# LANGGRAPH_INTERRUPT=true

# Optional: persistence backend
CHECKPOINTER=memory
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/langgraph_lab

LOG_LEVEL=INFO
